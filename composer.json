{
    "name": "rickselby/laravel-gate-cache",
    "description": "Add a per-request caching layer to Laravel's Gate",
    "minimum-stability": "stable",
    "license": "MIT",
    "authors": [
        {
            "name": "Rick Selby",
            "email": "rick@selby-family.co.uk"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/auth": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/contracts": "^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "graham-campbell/testbench": "^6.3",
        "laravel/pint": "^1.14",
        "phpunit/phpunit": "^10.5 || ^11.5 || ^12.5"
    },
    "autoload": {
        "psr-4": {
            "RickSelby\\Laravel\\GateCache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RickSelby\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "format": "pint"
    },
    "config": {
        "allow-plugins": {
            "kylekatarnls/update-helper": false
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "RickSelby\\Laravel\\GateCache\\GateCacheProvider"
            ]
        }
    }
}
